# =============================================================================
# FaynoSync 环境变量配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env
# =============================================================================

PORT=9000
ALLOWED_CORS=http://localhost:3000
API_URL=http://localhost:9000
MONGODB_URL=mongodb://root:changeme@db:27017/faynosync?authSource=admin
API_KEY=
MONGODB_URL_TESTS=mongodb://root:changeme@db:27017/faynosync_tests?authSource=admin
JWT_SECRET=
ENABLE_PRIVATE_APP_DOWNLOADING=false
ENABLE_TELEMETRY=false

# =============================================================================
# MINIO (local or cloud S3-compatible storage)
# =============================================================================
STORAGE_DRIVER=minio
MINIO_SECURE=false
S3_BUCKET_NAME_PRIVATE=faynosync-private
S3_ENDPOINT_PRIVATE=s3:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=faynosync-public
S3_ENDPOINT=s3:9000

# =============================================================================
# AWS S3 (Amazon Simple Storage Service)
# =============================================================================
#STORAGE_DRIVER=aws
#S3_ACCESS_KEY=
#S3_SECRET_KEY=
#S3_REGION=
#S3_BUCKET_NAME_PRIVATE=
#S3_BUCKET_NAME=
#S3_ENDPOINT_PRIVATE=https://<bucket_name>.s3.amazonaws.com
#S3_ENDPOINT=https://<bucket_name>.s3.amazonaws.com

# =============================================================================
# DIGITALOCEAN SPACES (S3-compatible storage from DigitalOcean)
# =============================================================================
#STORAGE_DRIVER=digitalocean
#S3_ENDPOINT_PRIVATE=nyc3.digitaloceanspaces.com
#S3_REGION=nyc3
#S3_ACCESS_KEY=
#S3_SECRET_KEY=
#S3_BUCKET_NAME_PRIVATE=
#S3_BUCKET_NAME=

# =============================================================================
# GOOGLE CLOUD STORAGE (GCP)
# =============================================================================
#STORAGE_DRIVER=gcp
#GCS_CREDENTIALS_FILE=/path/to/credentials.json
#GCS_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
#GCS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n
#S3_BUCKET_NAME_PRIVATE=
#S3_BUCKET_NAME=

################### Performance Configuration ###################
PERFORMANCE_MODE=true
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

################### Slack Configuration ###################
SLACK_ENABLE=false
SLACK_BOT_TOKEN=
SLACK_CHANNEL=

################### TUF Configuration ###################
TUF_ENABLED=false
ONLINE_KEY_DIR=/private_keys

# =============================================================================
# Docker Compose 专用（非 FaynoSync 原生变量）
# =============================================================================
MONGO_USERNAME=root
MONGO_PASSWORD=changeme
API_PORT=9000
DASHBOARD_PORT=3000
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011
